<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Header</title>
    <link rel="stylesheet" href="/styles/header.css" />
  </head>
  <body>
    <!-- Header -->
    <header>
      <!-- Logo -->
      <a href="/"><h1 class="header-logo">🔑Members Only Club</h1></a>

      <% if (user) { %>
        <a href="/logout">
          <button class="header-btn log-out-btn">Log Out</button>
        </a>
      <% } else { %>
        <!-- Buttons -->
        <div class="header-btn-group">

          <!-- Log In -->
          <a href="/login">
            <button class="header-btn log-in-btn">Log In</button>
          </a>

          <!-- Sign Up -->
          <a href="/signup">
            <button class="header-btn sign-up-btn">Sign Up</button>
          </a>
        </div>
      <% } %>
    </header>
  </body>
</html>
